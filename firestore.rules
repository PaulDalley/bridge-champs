rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user has valid subscription
    function hasValidSubscription() {
      return request.auth != null &&
             get(/databases/$(database)/documents/members/$(request.auth.uid)).data.subscriptionExpires >= request.time;
    }
    
    // Helper function to check if user has premium tier
    function hasPremiumTier() {
      return hasValidSubscription() &&
             get(/databases/$(database)/documents/members/$(request.auth.uid)).data.tier == "premium";
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.OK == true;
    }

    function canCreateNewQuestion() {
      return !(get(/databases/$(database)/documents/membersData/$(request.auth.uid)).data.blocked) 
                ||
              get(/databases/$(database)/documents/membersData/$(request.auth.uid)).data.lastQuestion < request.time;
    }

    function isArticleTopCapturePayload() {
      return request.resource.data.signupSource == "article-top-capture"
        && request.resource.data.firstName is string
        && request.resource.data.firstName.size() >= 2
        && request.resource.data.firstName.size() <= 40
        && request.resource.data.surname is string
        && request.resource.data.surname.size() >= 2
        && request.resource.data.surname.size() <= 40
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.sourcePath is string
        && request.resource.data.articleId is string
        && request.resource.data.articleType is string
        && request.resource.data.articleTitle is string
        && request.resource.data.userAgent is string
        && !request.resource.data.userAgent.matches("(?i).*(bot|crawler|spider|headless|phantom|puppeteer|selenium|chrome/1).*");
    }

    function validMembersDataWrite(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && (
          !("signupSource" in request.resource.data)
          || request.resource.data.signupSource != "article-top-capture"
          || isArticleTopCapturePayload()
        );
    }

    match /freeDaily/{contentType} {
      allow read;
      allow update: if isAdmin();
    }
    
    match /questions/{questionId} {
      allow read;
      allow create: if hasValidSubscription();
      allow update, delete: if get(/databases/$(database)/documents/questions/$(questionId)).uid == request.auth.uid;
    }

    match /members/{memberId} {
        allow read;
        allow create, delete: if isAdmin();
        allow update: if isAdmin()
            || (
                request.auth != null
                && request.auth.uid == memberId
                && request.resource.data.diff(resource.data).affectedKeys()
                    .hasOnly(['referralCode', 'referralCodeCreatedAt'])
            );
    }

    match /membersData/{userId} {
        allow read, create, update: if validMembersDataWrite(userId);
    }

    // User system card — each user can read/write their own
    match /userSystemCards/{userId} {
        allow read, create, update: if request.auth.uid == userId;
    }

    match /users/{userId} {
        allow read;
    }

    match /categories/{category} {
        allow read;
        allow create, update, delete: if isAdmin();
    }

    // Public metadata collections (summaries only)
    match /articles/{articleId} {
        allow read;
        allow create, update, delete: if isAdmin();
    }

    match /defence/{defenceId} {
        allow read;
        allow create, update, delete: if isAdmin();
    }

    match /cardPlay/{cardPlayId} {
        allow read;
        allow create, update, delete: if isAdmin();
    }

    match /bidding/{biddingId} {
        allow read;
        allow create, update, delete: if isAdmin();
    }    

    match /counting/{countingId} {
        allow read;
        allow create, update, delete: if isAdmin();
    }

    // Beginner pillar — article summaries (public read, same pattern as cardPlay/defence)
    match /beginnerCardPlay/{articleId} {
        allow read;
        allow create, update, delete: if isAdmin();
    }

    match /beginnerDefence/{articleId} {
        allow read;
        allow create, update, delete: if isAdmin();
    }

    match /beginnerBidding/{articleId} {
        allow read;
        allow create, update, delete: if isAdmin();
    }

    match /quizzes/{quizId} {
        allow read;
        allow create, update, delete: if isAdmin();
    }

    // Videos metadata - publicly readable, but content will be blocked in UI for non-premium

    match /userTokens/{tokenId} {
        allow read;
        allow create, update, delete: if isAdmin();
    }

    // Promo usage attribution (affiliate reporting).
    // Users can create a row for themselves at checkout; only admins can read/manage.
    match /promoCodeUsage/{entryId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.promoCodeEntered is string
        && request.resource.data.promoCodeApplied is string
        && request.resource.data.provider is string
        && request.resource.data.status is string;
      allow read, update, delete: if isAdmin();
    }

    match /videos/{videoId} {
        allow read;
        allow create, update, delete: if isAdmin();
    }

    // Protected content - requires basic ($25) or premium ($50) subscription
    match /article/{articleId} {
      allow read: if hasValidSubscription() || isAdmin() || resource.data.isFree == true;
      allow create, update, delete: if isAdmin();
    }

    match /biddingBody/{biddingBodyId} {
      allow read: if hasValidSubscription() || isAdmin() || resource.data.isFree == true;
      allow create, update, delete: if isAdmin();
    }

    match /cardPlayBody/{cardPlayBodyId} {
      allow read: if hasValidSubscription() || isAdmin() || resource.data.isFree == true;
      allow create, update, delete: if isAdmin();
    }

    match /defenceBody/{defenceBodyId} {
      allow read: if hasValidSubscription() || isAdmin() || resource.data.isFree == true;
      allow create, update, delete: if isAdmin();
    }

    match /countingBody/{countingBodyId} {
      allow read: if hasValidSubscription() || isAdmin() || resource.data.isFree == true;
      allow create, update, delete: if isAdmin();
    }

    match /beginnerCardPlayBody/{bodyId} {
      allow read: if hasValidSubscription() || isAdmin() || resource.data.isFree == true;
      allow create, update, delete: if isAdmin();
    }

    match /beginnerDefenceBody/{bodyId} {
      allow read: if hasValidSubscription() || isAdmin() || resource.data.isFree == true;
      allow create, update, delete: if isAdmin();
    }

    match /beginnerBiddingBody/{bodyId} {
      allow read: if hasValidSubscription() || isAdmin() || resource.data.isFree == true;
      allow create, update, delete: if isAdmin();
    }

    match /quiz/{quizId} {
      allow read: if hasValidSubscription() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Article body backups - admin only
    match /cardPlayBodyBackups/{backupId} {
      allow read, create, update, delete: if isAdmin();
    }
    match /defenceBodyBackups/{backupId} {
      allow read, create, update, delete: if isAdmin();
    }
    match /biddingBodyBackups/{backupId} {
      allow read, create, update, delete: if isAdmin();
    }
    match /countingBodyBackups/{backupId} {
      allow read, create, update, delete: if isAdmin();
    }

    // Category banners - publicly readable, admin writable
    match /categoryBanners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Article feedback - anyone can create, admins can read
    match /articleFeedback/{feedbackId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // Category feedback - anyone can create, admins can read
    match /categoryFeedback/{feedbackId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // Newsletter lead capture from article pages. Public create so SEO visitors
    // can submit without an account; admin-only read/manage in console.
    match /newsletterLeads/{leadId} {
      allow create: if request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 254
        && request.resource.data.source is string
        && request.resource.data.sourcePath is string
        && request.resource.data.articleId is string
        && request.resource.data.articleType is string
        && request.resource.data.articleTitle is string
        && request.resource.data.status is string;
      allow read, update, delete: if isAdmin();
    }

    match /handSubmissions/{submissionId} {
      // Logged-in users can submit; only admins can read/manage.
      allow create: if request.auth != null;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Basic usage tracking: logged-in users can write their own events.
    // View the logs in Firebase Console (admin). We do not expose read access to clients.
    match /activityLogs/{logId} {
      allow create: if request.auth != null &&
                    request.resource.data.uid == request.auth.uid &&
                    request.resource.data.eventType is string &&
                    request.resource.data.path is string;
      allow read, update, delete: if false;
    }

    // Quiz categories - publicly readable, admin writable
    match /quizCategories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Treadmill hand-shape streak: one doc per user (uid), best time only; world-readable top list
    match /treadmillStreakScores/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.alias is string
        && request.resource.data.alias.size() <= 40
        && request.resource.data.timeMs is number
        && request.resource.data.timeMs >= 2000
        && request.resource.data.timeMs <= 600000;
      allow delete: if false;
    }

    // Card Rush — best 2-min Puzzle-Rush score per user (uid). World-readable.
    // Score = puzzles correct in the run; timeMs = elapsed time (used as tiebreaker).
    match /cardRushScores/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.alias is string
        && request.resource.data.alias.size() <= 40
        && request.resource.data.score is number
        && request.resource.data.score >= 1
        && request.resource.data.score <= 999
        && request.resource.data.timeMs is number
        && request.resource.data.timeMs >= 0
        && request.resource.data.timeMs <= 300000;
      allow delete: if false;
    }
  }
}
