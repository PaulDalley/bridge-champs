# Firestore Admin credentials for build/ISR reads.
# Local dev/build: point at a service-account key file...
#   GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/serviceAccountKey.json
# ...or inline the JSON:
#   FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
# On Cloud Run: omit both and grant the runtime service account Firestore read access
# (applicationDefault() picks it up automatically).
FIREBASE_SERVICE_ACCOUNT=

# Shared secret the CRA admin editor sends to POST /api/revalidate on publish.
REVALIDATE_SECRET=
